{
  "name": "pair-reviewer",
  "version": "1.2.0",
  "description": "AI-powered PR reviewer GitHub Action using GitHub Models",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --sourcemap",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^9.1.1",
    "@azure-rest/ai-inference": "^1.0.0-beta.6",
    "@azure/core-auth": "^1.10.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^4.1.6",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "undici": ">=6.23.1 <8"
  },
  "engines": {
    "node": ">=20"
  }
}
